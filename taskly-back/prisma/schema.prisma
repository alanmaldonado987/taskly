// ==========================================
// TASKLY DATABASE SCHEMA
// Designed for scalability
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AUTH / USERS
// ==========================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash String   @map("password_hash")
  name         String
  
  // Estado
  isEmailVerified Boolean @default(false) @map("is_email_verified")
  isActive      Boolean @default(true) @map("is_active")
  
  // Avatar
  avatar       String?
  
  // Preferencias
  locale       String   @default("es") // es, en
  timezone     String   @default("America/Argentina/Buenos_Aires")
  theme        Theme   @default(SYSTEM)
  
  // Último login
  lastLoginAt   DateTime? @map("last_login_at")
  lastLoginIp  String?  @map("last_login_ip")
  
  // Relations
  sessions     Session[]
  organizationUsers OrganizationUser[]
  projectMemberships ProjectMember[] // Para cuando un user es también member
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Theme {
  LIGHT  @map("light")
  DARK   @map("dark")
  SYSTEM @map("system")
}

// Sessions para JWT
model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Token info
  token       String   @unique
  tokenType   SessionType @default(ACCESS)
  
  // Dispositivo
  userAgent   String?  @map("user_agent")
  ipAddress  String?  @map("ip_address")
  device    String?  // Desktop, Mobile, Tablet
  browser   String?  // Chrome, Firefox, Safari
  os        String?  // Windows, MacOS, Linux, Android, iOS
  
  // Ubicación (opcional, para security)
  country   String?
  city      String?
  
  // Estado
  isRevoked  Boolean @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at")
  
  // Última actividad
  lastActiveAt DateTime @map("last_active_at")
  createdAt  DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([token])
  @@map("sessions")
}

enum SessionType {
  ACCESS   @map("access")   // JWT access token
  REFRESH  @map("refresh")  // JWT refresh token
}

// Verification codes (email, password reset)
model VerificationCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  
  code     String
  type     VerificationType
  
  // Estado
  isUsed   Boolean @default(false) @map("is_used")
  expiresAt DateTime @map("expires_at")
  usedAt   DateTime? @map("used_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  
  @@unique([userId, code, type])
  @@index([code])
  @@map("verification_codes")
}

enum VerificationType {
  EMAIL_VERIFY    @map("email_verify")
  PASSWORD_RESET @map("password_reset")
}

// ==========================================
// TENANT / ORGANIZATION (para escalar)
// ==========================================

model Organization {
  id        String   @id @default(uuid())
  name     String
  slug     String  @unique // Para URLs: taskly.com/mi-empresa
  logo     String?
  website  String?
  
  // Settings
  settings Json?    // Configuración global de la organización
  
  // Relations
  projects  Project[]
  users     OrganizationUser[]
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organizations")
}

// Usuario enlazado a organización (para después)
model OrganizationUser {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  userId         String @map("user_id")
  role           OrganizationRole @default(MEMBER)
  
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime @default(now()) @map("created_at")
  
  @@unique([organizationId, userId])
  @@map("organization_users")
}

enum OrganizationRole {
  OWNER   @map("owner")
  ADMIN  @map("admin")
  MEMBER @map("member")
  GUEST  @map("guest")
}

// ==========================================
// PROJECT
// ==========================================

model Project {
  id           String   @id @default(uuid())
  name         String
  description String?
  slug         String?  // Para URLs limpias
  
  // Settings del proyecto
  settings    ProjectSettings? // Configuración específica
  
  // Relations
  tasks        Task[]
  members     ProjectMember[]
  comments    Comment[]
  attachments Attachment[]
  activities  Activity[]
  organizationId String?  @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("projects")
}

model ProjectSettings {
  id                    String  @id @default(uuid())
  projectId             String  @unique @map("project_id")
  
  // Vistas
  defaultView           ViewType @default(GANTT) @map("default_view")
  visibleViews          ViewType[] @default([GANTT, BOARD, GRID, WORKLOAD, CALENDAR]) @map("visible_views")
  
  // Gantt
  defaultZoomLevel      ZoomLevel @default(WEEK) @map("default_zoom_level")
  showWeekends          Boolean @default(true) @map("show_weekends")
  showTodayLine         Boolean @default(true) @map("show_today_line")
  
  // Board
  boardColumns         TaskStatus[] @default([OPEN, IN_PROGRESS, DONE, CLOSED]) @map("board_columns")
  boardGroupBy          GroupByType @default(STATUS) @map("board_group_by")
  
  // Workload
  workingHoursPerDay   Int @default(8) @map("working_hours_per_day")
  workingDaysPerWeek   Int @default(5) @map("working_days_per_week")
  
  // Colors
  taskColors           String[] @default(["#ef4444", "#f97316", "#eab308", "#22c55e", "#14b8a6", "#3b82f6", "#8b5cf6", "#ec4899"]) @map("task_colors")
  
  // Features
  enableComments       Boolean @default(true) @map("enable_comments")
  enableAttachments   Boolean @default(true) @map("enable_attachments")
  enableTimeTracking   Boolean @default(true) @map("enable_time_tracking")
  enableDependencies   Boolean @default(true) @map("enable_dependencies")
  enableSubtasks       Boolean @default(true) @map("enable_subtasks")
  enableMilestones     Boolean @default(true) @map("enable_milestones")
  
  project              Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("project_settings")
}

enum ViewType {
  GANTT     @map("gantt")
  BOARD    @map("board")
  GRID     @map("grid")
  LIST     @map("list")
  WORKLOAD @map("workload")
  CALENDAR @map("calendar")
  PEOPLE   @map("people")
  DASHBOARD @map("dashboard")
}

enum ZoomLevel {
  DAY    @map("day")
  WEEK   @map("week")
  MONTH @map("month")
}

enum GroupByType {
  STATUS   @map("status")
  PRIORITY @map("priority")
  ASSIGNED @map("assigned")
  NONE    @map("none")
}

// ==========================================
// TEAM MEMBERS
// ==========================================

model ProjectMember {
  id           String   @id @default(uuid())
  name        String
  email       String
  avatar      String?
  color       String   // Hex color para mostrar en UI
  
  // Opcional: ссылка на User autenticado
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Rol en el proyecto
  role        ProjectRole @default(MEMBER)
  
  // Availability (para workload)
  hoursPerWeek Int?    @default(40) @map("hours_per_week")
  
  // Relations
  projectId   String   @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  tasks      Task[]    @relation("TaskAssignees")
  comments  Comment[]
  activities Activity[]
  uploadedAttachments Attachment[]
  
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Un usuario puede ser miembro de muchos proyectos con el mismo email
  @@unique([projectId, email])
  @@index([userId])
  @@map("project_members")
}

enum ProjectRole {
  OWNER   @map("owner")
  ADMIN  @map("admin")
  MEMBER @map("member")
  VIEWER @map("viewer")
}

// ==========================================
// TASKS
// ==========================================

model Task {
  id            String   @id @default(uuid())
  name          String
  description  String?
  
  // Fechas
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  
  // Progreso y estado
  progress    Int      @default(0) @map("progress") // 0-100
  status      TaskStatus @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  
  // Metadatos
  color       String   @map("color") // Hex color para la barra en Gantt
  isMilestone Boolean  @default(false) @map("is_milestone")
  
  // Time tracking
  estimatedHours Int?   @map("estimated_hours")
  loggedHours   Int?    @map("logged_hours")
  
  // Ordenamiento (para drag & drop en grid/board)
  sortOrder   Int      @default(0) @map("sort_order")
  
  // Visibility (para archiving)
  isArchived Boolean  @default(false) @map("is_archived")
  
  // Relations
  projectId   String   @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assignees   ProjectMember[] @relation("TaskAssignees")
  
  // Jerarquía (subtareas)
  parentId    String?   @map("parent_id")
  parent     Task?     @relation("TaskHierarchy", fields: [parentId], references: [id])
  children  Task[]    @relation("TaskHierarchy")
  
  // Dependencias (tareas de las que depende esta tarea)
  dependsOn    TaskDependency[] @relation("TaskDependees")
  // Tareas que dependen de esta tarea
  dependents  TaskDependency[] @relation("TaskDependents")
  
  // Comentarios, archivos, actividad
  comments    Comment[]
  attachments Attachment[]
  activities  Activity[]
  
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([projectId, status])
  @@index([projectId, priority])
  @@index([projectId, startDate])
  @@index([projectId, endDate])
  @@index([parentId])
  @@map("tasks")
}

enum TaskStatus {
  OPEN       @map("open")
  IN_PROGRESS @map("in_progress")
  DONE      @map("done")
  CLOSED     @map("closed")
}

enum TaskPriority {
  LOWEST    @map("lowest")
  LOW      @map("low")
  MEDIUM   @map("medium")
  HIGH     @map("high")
  HIGHEST  @map("highest")
}

// ==========================================
// TASK DEPENDENCIES
// ==========================================

model TaskDependency {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  dependsOnId String   @map("depends_on_id")
  
  // Tipo de dependencia
  type       DependencyType @default(FINISH_TO_START)
  
  // Relations
  task       Task  @relation("TaskDependents", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn  Task  @relation("TaskDependees", fields: [dependsOnId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now()) @map("created_at")
  
  @@unique([taskId, dependsOnId])
  @@map("task_dependencies")
}

enum DependencyType {
  FINISH_TO_START   @map("finish_to_start")   // B depende de A (A termina, B puede empezar)
  START_TO_START    @map("start_to_start")    // B empieza cuando A empieza
  FINISH_TO_FINISH  @map("finish_to_finish")  // B termina cuando A termina
  START_TO_FINISH   @map("start_to_finish")   // B termina cuando A empieza
}

// ==========================================
// COMMENTS
// ==========================================

model Comment {
  id        String   @id @default(uuid())
  content  String
  
  // Relations
  taskId    String   @map("task_id")
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  authorId String   @map("author_id")
  author   ProjectMember @relation(fields: [authorId], references: [id])
  
  projectId String  @map("project_id")
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Para editing
  isEdited Boolean @default(false) @map("is_edited")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@index([taskId])
  @@map("comments")
}

// ==========================================
// ATTACHMENTS
// ==========================================

model Attachment {
  id          String   @id @default(uuid())
  name       String
  url        String   // URL del archivo en S3/local storage
  size       Int      @map("size") // bytes
  
  // Tipo de archivo
  mimeType   String?  @map("mime_type")
  extension String?  @map("extension")
  
  // Relations
  taskId     String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  uploadedById String  @map("uploaded_by_id")
  uploadedBy  ProjectMember @relation(fields: [uploadedById], references: [id])
  
  projectId String   @map("project_id")
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt DateTime  @default(now()) @map("created_at")
  
  @@index([taskId])
  @@map("attachments")
}

// ==========================================
// ACTIVITY LOG
// ==========================================

model Activity {
  id          String   @id @default(uuid())
  
  // Tipo de actividad
  type        ActivityType
  description String? // Descripción adicional
  
  // Datos del cambio (JSON para flexibilidad)
  previous   Json?    // Estado anterior
  current    Json?    // Estado nuevo
  
  // Relations
  taskId      String?  @map("task_id")
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  projectId  String   @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  performedById String @map("performed_by_id")
  performedBy ProjectMember @relation(fields: [performedById], references: [id])
  
  createdAt  DateTime @default(now()) @map("created_at")
  
  @@index([projectId, createdAt(sort: Desc)])
  @@index([taskId])
  @@map("activities")
}

enum ActivityType {
  TASK_CREATED     @map("task_created")
  TASK_UPDATED    @map("task_updated")
  TASK_DELETED    @map("task_deleted")
  TASK_MOVED      @map("task_moved")
  TASK_PROGRESS   @map("task_progress")
  COMMENT_ADDED   @map("comment_added")
  FILE_UPLOADED   @map("file_uploaded")
  MEMBER_ADDED   @map("member_added")
  MEMBER_REMOVED @map("member_removed")
  STATUS_CHANGED  @map("status_changed")
}

